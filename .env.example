# CarbonScope environment configuration
# Copy to .env and fill in real values for production

# Environment: development | production | test
ENV=development

SECRET_KEY=change-me-to-a-random-64-char-string
DATABASE_URL=sqlite+aiosqlite:///./carbonscope.db
# PostgreSQL example:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/carbonscope
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
LOG_JSON=false
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_DEFAULT=60/minute
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Cookie settings (production)
# COOKIE_DOMAIN=.carbonscope.io
# COOKIE_SECURE=true

# MFA / TOTP encryption key — required in production
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# TOTP_ENCRYPTION_KEY=

# Estimation: local (dev) or subnet (production Bittensor)
ESTIMATION_MODE=local

# Validator scores file path (Bittensor subnet)
# VALIDATOR_SCORES_PATH=scores.json

# Bittensor (optional — used when ESTIMATION_MODE=subnet)
BT_NETWORK=test
BT_NETUID=1
BT_WALLET_NAME=api_client
BT_WALLET_HOTKEY=default
BT_QUERY_TIMEOUT=30.0

# Email / SMTP (optional — logs emails if not configured)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# EMAIL_FROM=noreply@carbonscope.io

# LLM / AI (optional — uses rule-based fallback if not set)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Stripe (optional — for subscription billing)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PostgreSQL password (used by docker-compose.prod.yml)
# POSTGRES_PASSWORD=strong-random-password

# Redis (optional — distributed rate limiting & caching)
# REDIS_URL=redis://localhost:6379/0

# Prometheus metrics (set true to expose /metrics in Prometheus format)
# PROMETHEUS_ENABLED=false

# Sentry (optional — error tracking & performance monitoring)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# OpenTelemetry (optional — distributed tracing)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Application version (used by Sentry & OTEL releases)
# APP_VERSION=0.21.0

# Trust reverse proxy headers (X-Forwarded-For) for rate limiting
# Set to true when behind nginx, ALB, or Cloudflare
# TRUST_PROXY=false
